{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "eagle-ai",
  "version": "1.3.1",
  "identifier": "com.eagle.eagleai",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build && cd src-python && python build_backend.py",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "EagleAI \u2014 ST Edition",
        "width": 1400,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "center": true,
        "visible": true,
        "decorations": true,
        "resizable": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb", "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/eagle-sidecar"
    ],
    "resources": [
      "../src-python/state/*.json",
      "../src-python/data/*.xls"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}